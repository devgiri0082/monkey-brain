{
  "manifest_version": 3,
  "name": "Monkey Brain",
  "short_name": "Monkey Brain",
  "version": "1.1.0",
  "description": "Tame your monkey brain by blocking addictive short-form content like Facebook Reels and algorithmic homepages.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Settings"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://www.instagram.com/*",
        "https://instagram.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
