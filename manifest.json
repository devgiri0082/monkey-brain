{
  "manifest_version": 3,
  "name": "YouTube Home to Subscriptions",
  "short_name": "YT to Subs",
  "version": "1.0.0",
  "description": "Automatically and instantly redirects the YouTube homepage to your subscriptions feed.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
